rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == "casar70@gmail.com";
    }

    function pedidoEditalValido(pedidoId) {
      return signedIn()
        && pedidoId == request.auth.uid
        && request.resource.data.keys().hasOnly(["texto", "status", "criadoEm", "usuario", "savedAt"])
        && request.resource.data.texto is string
        && request.resource.data.texto.size() >= 3
        && request.resource.data.texto.size() <= 500
        && request.resource.data.status == "novo"
        && request.resource.data.criadoEm is string
        && request.resource.data.criadoEm.size() >= 10
        && request.resource.data.criadoEm.size() <= 40
        && request.resource.data.usuario is map
        && request.resource.data.usuario.keys().hasOnly(["uid", "email", "nome"])
        && request.resource.data.usuario.uid == request.auth.uid
        && request.resource.data.usuario.email is string
        && request.resource.data.usuario.email.size() <= 254
        && request.resource.data.usuario.nome is string
        && request.resource.data.usuario.nome.size() <= 120
        && request.resource.data.savedAt is timestamp;
    }

    // Estado principal (current) + backups diários (backup-0..backup-6),
    // todos privados do dono.
    match /users/{userId}/state/{docId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    // Tokens de push (lembretes de estudo). O dono escreve; o Cloud Function (admin) lê.
    match /users/{userId}/push/{docId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    // Catálogo de editais: leitura pública (vitrine/demo para visitantes não
    // logados); somente o admin publica/edita. Contém apenas metadados e capas
    // de editais — nada sensível.
    match /public/catalogo {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pedidosEdital/{pedidoId} {
      // Um documento por usuário evita crescimento ilimitado/spam da coleção.
      // Um novo pedido substitui o anterior do próprio usuário; o admin continua
      // podendo marcar como atendido ou excluir.
      allow create, update: if isAdmin() || pedidoEditalValido(pedidoId);
      allow read, delete: if isAdmin();
    }
  }
}
