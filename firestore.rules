rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == "casar70@gmail.com";
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isStateMetadataId(docId) {
      return docId == "current" || docId.matches("^backup-[0-6]$");
    }

    function isStateChunkId(docId) {
      return docId.matches("^(current|backup-[0-6])-chunk-(0[0-9]|1[0-9]|2[0-3])$");
    }

    function validSummary(summary) {
      return summary is map
        && summary.keys().hasOnly(["registros", "planos"])
        && summary.registros is int
        && summary.registros >= 0
        && summary.planos is int
        && summary.planos >= 0;
    }

    function validCurrentMetadata() {
      return request.resource.data.keys().hasOnly([
          "formato", "chunks", "updatedAt", "clientId", "syncGeneration", "rev", "resumo", "savedAt"
        ])
        && request.resource.data.formato == 2
        && request.resource.data.chunks is int
        && request.resource.data.chunks >= 1
        && request.resource.data.chunks <= 24
        && request.resource.data.updatedAt is string
        && request.resource.data.updatedAt.size() <= 40
        && request.resource.data.clientId is string
        && request.resource.data.clientId.size() <= 120
        && (!("syncGeneration" in request.resource.data) ||
          (request.resource.data.syncGeneration is string
            && request.resource.data.syncGeneration.size() >= 8
            && request.resource.data.syncGeneration.size() <= 120))
        && request.resource.data.rev is int
        && request.resource.data.rev >= 0
        && validSummary(request.resource.data.resumo)
        && request.resource.data.savedAt is timestamp;
    }

    function validBackupMetadata() {
      return request.resource.data.keys().hasOnly([
          "formato", "chunks", "criadoEm", "clientId", "rev", "resumo", "savedAt"
        ])
        && request.resource.data.formato == 2
        && request.resource.data.chunks is int
        && request.resource.data.chunks >= 1
        && request.resource.data.chunks <= 24
        && request.resource.data.criadoEm is string
        && request.resource.data.criadoEm.size() <= 40
        && request.resource.data.clientId is string
        && request.resource.data.clientId.size() <= 120
        && request.resource.data.rev is int
        && request.resource.data.rev >= 0
        && validSummary(request.resource.data.resumo)
        && request.resource.data.savedAt is timestamp;
    }

    // Compatibilidade durante a migração do documento único para o formato 2.
    function validLegacyCurrent() {
      return request.resource.data.keys().hasOnly([
          "state", "updatedAt", "clientId", "savedAt"
        ])
        && request.resource.data.state is map
        && request.resource.data.updatedAt is string
        && request.resource.data.updatedAt.size() <= 40
        && request.resource.data.clientId is string
        && request.resource.data.clientId.size() <= 120
        && request.resource.data.savedAt is timestamp;
    }

    function validLegacyBackup() {
      return request.resource.data.keys().hasOnly([
          "state", "criadoEm", "clientId", "savedAt"
        ])
        && request.resource.data.state is map
        && request.resource.data.criadoEm is string
        && request.resource.data.criadoEm.size() <= 40
        && request.resource.data.clientId is string
        && request.resource.data.clientId.size() <= 120
        && request.resource.data.savedAt is timestamp;
    }

    function validStateMetadata(docId) {
      return docId == "current"
        ? (validCurrentMetadata() || validLegacyCurrent())
        : (docId.matches("^backup-[0-6]$") && (validBackupMetadata() || validLegacyBackup()));
    }

    // Depois que uma conta tem uma geração oficial, clientes antigos (que ainda
    // não enviam syncGeneration) não podem voltar a gravar o documento principal.
    // A operação atômica inteira falha, inclusive os chunks.
    function keepsPrincipalMarker(docId) {
      return docId != "current"
        || !("syncGeneration" in resource.data)
        || ("syncGeneration" in request.resource.data);
    }

    function validStateWrite(docId) {
      return (isStateMetadataId(docId) && validStateMetadata(docId))
        || (isStateChunkId(docId) && validStateChunk());
    }

    function validStateChunk() {
      return request.resource.data.keys().hasOnly(["payload", "index", "rev", "savedAt"])
        && request.resource.data.payload is string
        && request.resource.data.payload.size() <= 180000
        && request.resource.data.index is int
        && request.resource.data.index >= 0
        && request.resource.data.index < 24
        && request.resource.data.rev is int
        && request.resource.data.rev >= 0
        && request.resource.data.savedAt is timestamp;
    }

    function pedidoEditalValido(pedidoId) {
      return signedIn()
        && pedidoId == request.auth.uid
        && request.resource.data.keys().hasOnly(["texto", "status", "criadoEm", "usuario", "savedAt"])
        && request.resource.data.texto is string
        && request.resource.data.texto.size() >= 3
        && request.resource.data.texto.size() <= 500
        && request.resource.data.status == "novo"
        && request.resource.data.criadoEm is string
        && request.resource.data.criadoEm.size() >= 10
        && request.resource.data.criadoEm.size() <= 40
        && request.resource.data.usuario is map
        && request.resource.data.usuario.keys().hasOnly(["uid", "email", "nome"])
        && request.resource.data.usuario.uid == request.auth.uid
        && request.resource.data.usuario.email is string
        && request.resource.data.usuario.email.size() <= 254
        && request.resource.data.usuario.nome is string
        && request.resource.data.usuario.nome.size() <= 120
        && request.resource.data.savedAt is timestamp;
    }

    // Estado principal, sete backups e até 24 partes por estado. IDs arbitrários
    // são negados para impedir que uma conta crie documentos ilimitados.
    match /users/{userId}/state/{docId} {
      allow read: if isOwner(userId) &&
        (isStateMetadataId(docId) || isStateChunkId(docId));
      allow create: if isOwner(userId) && validStateWrite(docId);
      allow update: if isOwner(userId) &&
        validStateWrite(docId) && keepsPrincipalMarker(docId);
      allow delete: if isOwner(userId) &&
        (isStateMetadataId(docId) || isStateChunkId(docId));
    }

    // Um único documento e no máximo 20 dispositivos por conta. O Admin SDK da
    // Cloud Function ignora estas regras e continua podendo enviar lembretes.
    match /users/{userId}/push/{docId} {
      allow read: if isOwner(userId) && docId == "tokens";
      allow create, update: if isOwner(userId)
        && docId == "tokens"
        && request.resource.data is map
        && request.resource.data.size() <= 20;
      allow delete: if isOwner(userId) && docId == "tokens";
    }

    // Catálogo de editais: leitura pública; somente o administrador publica.
    match /public/catalogo {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pedidosEdital/{pedidoId} {
      // Um documento por usuário evita crescimento ilimitado/spam da coleção.
      allow create, update: if isAdmin() || pedidoEditalValido(pedidoId);
      allow read, delete: if isAdmin();
    }
  }
}
